// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas = ["clonex"]
}

model User {
  id String @id(map:"clonex_product_pkey") @default(cuid())
  username String @unique
  email String
  posts Post []
  passwordHash String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comments Comment[]
  likes Like[]
  followers Follow[] @relation("followers")
  following Follow[] @relation("following")

  @@schema("clonex")
}

model Post{
  id String @id(map:"clonex_post_pkey") @default(cuid())
  user User @relation(fields: [userId],references: [id] )
  userId String
  mediaUrl String
  caption String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  comments Comment[] 
  likes Like[]

  @@schema("clonex")
}


model Comment{
  id String @id(map:"clonex_comment_pkey") @default(cuid())
  user User @relation(fields: [userId],references: [id])
  post Post @relation(fields: [postId], references: [id])
  postId String 
  userId String
  text String
  created_at DateTime @default(now())
  likes Like []

  @@schema("clonex") 
}

model Like{
  id String @id(map:"clonex_like_pkey") @default(cuid())
  postId String?
  commentId String?
  userId String
  comment Comment? @relation(fields: [commentId],references: [id])
  post Post? @relation(fields: [postId], references: [id])
  created_at DateTime @default(now())
  user User @relation(fields: [userId],references: [id])

  @@schema("clonex")
}

model Follow{
  id String @id(map:"clonex_follow_pkey") @default(cuid())
  follower User @relation("followers",fields: [followerId],references: [id])
  following User @relation("following",fields: [followingId], references: [id])

  followerId String
  followingId String
  createdAt DateTime

  @@schema("clonex")
}

